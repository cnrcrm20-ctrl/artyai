{
  "name": "ArtyAI",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt",
  "postStartCommand": "bash .devcontainer/start.sh",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "ArtyAI API",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
